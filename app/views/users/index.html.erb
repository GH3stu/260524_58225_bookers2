<div class="container">
  <div class="row">
    <div class="col-md-3">
      <h2>User info</h2>
      <%= image_tag 'default-image.jpg', size: '100x100' %>
      <table class="table">
        <tbody>
          <tr>
            <th>name</th>
            <th><%= current_user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th><%= current_user.introduction %></th>
          </tr>
        </tbody>
      </table>
      
      <div class="row">
        <%= link_to edit_user_path(current_user), class: "btn btn-outline-secondary btn-block" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      </div>

      <h2 class="mt-3">New book</h2>
      <%= form_with model: Book.new, local: true do |f| %>
        <div class="form-group">
          <label>Title</label>
          <%= f.text_field :title, class: 'form-control' %>
        </div>
        <div class="form-group">
          <label>Opinion</label>
          <%= f.text_area :body, class: 'form-control' %>
        </div>
        <div class="form-group mt-3">
          <%= f.submit 'Create Book', class: 'btn btn-success' %>
        </div>
      <% end %>
    </div>

    <div class="col-md-8 offset-md-1">
      <h2>Users</h2>
      <table class="table">
        <thead>
          <tr>
            <th>image</th>
            <th>name</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= image_tag 'default-image.jpg', size: '50x50' %></td>
              <td><%= user.name %></td>
              <td><%= link_to "Show", user_path(user) %></td>
            </tr>

            <tr>
              <th>follows</th>
              <th>
                 <%= link_to user.followings.count, user_followings_path(user) %>
              </th>
            </tr>
            <tr>
              <th>followers</th>
              <th>
                <%= link_to user.followers.count, user_followers_path(user) %>
              </th>
            </tr>

            <% if current_user != user %>
              <% if current_user.following?(user) %>
                <%= link_to "フォロー外す", user_relationships_path(user.id), method: :delete %>
              <% else %>
                <%= link_to "フォローする", user_relationships_path(user.id), method: :post %>
              <% end %>
            <% end %>

          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
