<div class='container px-5 px-sm-0'>
  <div class='row'>
    <% if user_signed_in? %>
      <div class='col-md-3'>
        <h2>User info</h2>
        <table class='table'>
          <tr>
            <% if current_user.get_profile_image(100, 100).is_a?(String) %>
              <%= image_tag current_user.get_profile_image(100, 100), size: "100x100" %>
            <% else %>
              <%= image_tag current_user.get_profile_image(100, 100).processed %>
            <% end %>
          </tr>
          <tr>
            <th>name</th>
            <th><%= current_user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th><%= current_user.introduction %></th>
          </tr>
        </table>
        <div class='row'>
          <%= link_to edit_user_path(current_user), class: "btn btn-outline-secondary btn-block" do %>
            <i class="fas fa-user-cog"></i>
          <% end %>
        </div>

        <h2 class="mt-3">New book</h2>
        <%= form_with model: Book.new do |f| %>
          <div class="form-group">
            <%= f.label :title %>
            <%= f.text_field :title, class: 'form-control' %>
          </div>
          <div class="form-group">
            <%= f.label :opinion %>
            <%= f.text_area :body, class: 'form-control' %>
          </div>
          <%= f.submit 'Create Book', class: 'btn btn-success' %>
        <% end %>
      </div>
      <div class='col-md-8 offset-md-1'>
    <% else %>
      <div class='col-md-8 offset-md-2'>
    <% end %>

      <h2>Sign up</h2>
      <%= render "devise/shared/error_messages" %>
      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), local: true do |f| %>
        <div class="field">
          <%= f.label :name %><br />
          <%= f.text_field :name, autofocus: true %>
        </div>
        <div class="field">
          <%= f.label :email %><br />
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>
        <div class="field">
          <%= f.label :password %>
          <%= f.password_field :password, autocomplete: "new-password" %>
        </div>
        <div class="field">
          <%= f.label :password_confirmation %><br />
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>
        <div class="actions">
          <%= f.submit "Sign up" %>
        </div>
      <% end %>

      <% if user_signed_in? %>
        <h2>Books</h2>
        <table class='table table-hover table-inverse'>
          <thead>
            <tr>
              <th></th>
              <th>Title</th>
              <th>Opinion</th>
              <th colspan="3"></th>
            </tr>
          </thead>
          <tbody>
            <% current_user.books.each do |book| %>
              <tr>
                <td><%= image_tag current_user.get_profile_image(50, 50) %></td>
                <td><%= link_to book.title, book_path(book.id) %></td>
                <td><%= book.body %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>
</div>