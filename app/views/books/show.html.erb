<div class="container">
  <div class="row">
    <!-- 左側：サイドバー -->
    <div class="col-md-3">
      <h2>User info</h2>
      <!-- ユーザー画像（デフォルト画像を使用する想定） -->
      <%= image_tag 'default-image.jpg', size: '100x100' %>
      <table class="table">
        <tbody>
          <tr>
            <th>name</th>
            <th><%= @book.user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th><%= @book.user.introduction %></th>
          </tr>
        </tbody>
      </table>
      
      <div class="row">
        <%= link_to edit_user_path(@book.user), class: "btn btn-outline-secondary btn-block" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      </div>

      <h2 class="mt-3">New book</h2>
      <%= form_with model: Book.new, local: true do |f| %>
        <div class="form-group">
          <label>Title</label>
          <%= f.text_field :title, class: 'form-control' %>
        </div>
        <div class="form-group">
          <label>Opinion</label>
          <%= f.text_area :body, class: 'form-control' %>
        </div>
        <div class="form-group mt-3">
          <%= f.submit 'Create Book', class: 'btn btn-success' %>
        </div>
      <% end %>
    </div>

    <!-- 右側：本の詳細 -->
    <div class="col-md-8 offset-md-1">
      <h2>Book detail</h2>
      <table class="table">
        <tbody>
          <tr>
            <td>
              <%= link_to user_path(@book.user) do %>
                <%= image_tag 'default-image.jpg', size: '50x50' %><br>
                <%= @book.user.name %>
              <% end %>
            </td>
            <td><%= link_to @book.title, book_path(@book) %></td>
            <td><%= @book.body %></td>
            
            <!-- 投稿者本人であれば編集・削除ボタンを表示 -->
            <% if @book.user == current_user %>
              <td><%= link_to "Edit", edit_book_path(@book), class: "btn btn-sm btn-success" %></td>
              <td>
                <%= button_to "Destroy", book_path(@book), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
              </td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>