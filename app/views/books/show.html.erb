<h2>Book detail</h2>
<p>Title: <%= @book.title %></p>
<p>Opinion: <%= @book.body %></p>

<%= link_to 'Edit', edit_book_path(@book.id) %> | 
<%= link_to 'Back', books_path %> |
<%= button_to "Destroy", book_path(@book), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-link p-0 border-0" %>